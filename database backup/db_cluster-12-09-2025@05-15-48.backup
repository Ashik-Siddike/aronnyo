COPY supabase_migrations.schema_migrations (version, statements, name, created_by, idempotency_key) FROM stdin;
20250618124758	{"-- Contents table\nCREATE TABLE contents (\n  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),\n  title text NOT NULL,\n  subtitle text,\n  description text,\n  content_type text NOT NULL CHECK (content_type IN ('youtube', 'image', 'video')),\n  youtube_link text,\n  file_url text,\n  class text,\n  subject text,\n  created_at timestamptz DEFAULT now()\n);\n\n-- Users table (for custom roles)\nCREATE TABLE users (\n  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),\n  email text UNIQUE NOT NULL,\n  full_name text,\n  role text CHECK (role IN ('student', 'teacher', 'parent', 'admin')) DEFAULT 'student',\n  created_at timestamptz DEFAULT now()\n);\n\n-- Quiz table\nCREATE TABLE quizzes (\n  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),\n  content_id uuid REFERENCES contents(id) ON DELETE CASCADE,\n  title text NOT NULL,\n  questions jsonb NOT NULL,\n  created_at timestamptz DEFAULT now()\n);\n\n-- Results table\nCREATE TABLE results (\n  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),\n  user_id uuid REFERENCES users(id) ON DELETE CASCADE,\n  quiz_id uuid REFERENCES quizzes(id) ON DELETE CASCADE,\n  score int,\n  submitted_at timestamptz DEFAULT now()\n);\n\n-- Teams table\nCREATE TABLE teams (\n  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),\n  name text NOT NULL,\n  description text,\n  created_at timestamptz DEFAULT now()\n);\n\n-- Team Members table\nCREATE TABLE team_members (\n  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),\n  team_id uuid REFERENCES teams(id) ON DELETE CASCADE,\n  user_id uuid REFERENCES users(id) ON DELETE CASCADE,\n  joined_at timestamptz DEFAULT now()\n);\n"}	init_tables_247school	ashiksiddike@gmail.com	\N
20250618021047	{"CREATE TABLE IF NOT EXISTS grades (\n  id SERIAL PRIMARY KEY,\n  name TEXT NOT NULL UNIQUE\n);"}	create_grades_table	ashiksiddike@gmail.com	\N
20250618021051	{"CREATE TABLE IF NOT EXISTS subjects (\n  id SERIAL PRIMARY KEY,\n  name TEXT NOT NULL,\n  grade_id INTEGER REFERENCES grades(id) ON DELETE CASCADE\n);"}	create_subjects_table	ashiksiddike@gmail.com	\N
20250618035945	{"ALTER TABLE contents ADD COLUMN IF NOT EXISTS pages JSONB;"}	add_pages_column_to_contents	ashiksiddike@gmail.com	\N
20250625023329	{"create table chapters (\n  id bigserial primary key,\n  name text not null,\n  grade_id bigint references grades(id) on delete cascade,\n  subject_id bigint references subjects(id) on delete cascade,\n  \\"order\\" int default 1,\n  description text,\n  created_at timestamptz default now()\n);"}	create_chapters_table	ashiksiddike@gmail.com	\N
20250625024329	{"alter table contents add column chapter_id bigint references chapters(id) on delete set null;"}	add_chapter_id_to_contents	ashiksiddike@gmail.com	\N
20250625083017	{"create table if not exists profiles (\n  id uuid primary key references auth.users(id) on delete cascade,\n  name text,\n  age integer,\n  grade text,\n  avatar_url text,\n  created_at timestamp with time zone default now(),\n  updated_at timestamp with time zone default now()\n);\n-- Storage bucket for avatars\ninsert into storage.buckets (id, name, public) values ('avatars', 'avatars', true) on conflict do nothing;"}	create_profiles_table	ashiksiddike@gmail.com	\N
20250625083626	{"alter table profiles add column if not exists address text;\nalter table profiles add column if not exists gender text;\nalter table profiles add column if not exists bio text;"}	add_profile_fields_address_gender_bio	ashiksiddike@gmail.com	\N
20250625084615	{"create table if not exists achievements (\n  id bigserial primary key,\n  user_id uuid references auth.users(id) on delete cascade,\n  title text,\n  description text,\n  points integer,\n  created_at timestamp with time zone default now()\n);"}	create_achievements_table	ashiksiddike@gmail.com	\N
20250625084619	{"create table if not exists goals (\n  id bigserial primary key,\n  user_id uuid references auth.users(id) on delete cascade,\n  title text,\n  progress integer default 0,\n  total integer default 1,\n  created_at timestamp with time zone default now()\n);"}	create_goals_table	ashiksiddike@gmail.com	\N
20250625084623	{"create table if not exists activity (\n  id bigserial primary key,\n  user_id uuid references auth.users(id) on delete cascade,\n  activity_date date,\n  lessons_completed integer default 0,\n  time_spent_minutes integer default 0,\n  created_at timestamp with time zone default now()\n);"}	create_activity_table	ashiksiddike@gmail.com	\N
20250625084627	{"create table if not exists friends (\n  id bigserial primary key,\n  user_id uuid references auth.users(id) on delete cascade,\n  friend_id uuid references auth.users(id) on delete cascade,\n  status text default 'pending',\n  created_at timestamp with time zone default now()\n);"}	create_friends_table	ashiksiddike@gmail.com	\N
20250625092040	{"create or replace function count_profiles()\nreturns integer as $$\n  select count(*) from profiles;\n$$ language sql stable;\n\ncreate or replace function count_contents()\nreturns integer as $$\n  select count(*) from contents;\n$$ language sql stable;\n\ncreate or replace function count_subjects()\nreturns integer as $$\n  select count(*) from subjects;\n$$ language sql stable;"}	add_count_functions_for_hero_stats	ashiksiddike@gmail.com	\N
20250820025321	{"-- Ensure required extension for UUID (if not already)\ncreate extension if not exists pgcrypto;\n\n-- GRADES\nalter table if exists public.grades enable row level security;\ndrop policy if exists grades_select_all on public.grades;\ncreate policy grades_select_all on public.grades for select using (true);\ndrop policy if exists grades_modify_auth on public.grades;\ncreate policy grades_modify_auth on public.grades for all to authenticated using (true) with check (true);\n\n-- SUBJECTS\nalter table if exists public.subjects enable row level security;\ndrop policy if exists subjects_select_all on public.subjects;\ncreate policy subjects_select_all on public.subjects for select using (true);\ndrop policy if exists subjects_modify_auth on public.subjects;\ncreate policy subjects_modify_auth on public.subjects for all to authenticated using (true) with check (true);\n\n-- CHAPTERS\nalter table if exists public.chapters enable row level security;\ndrop policy if exists chapters_select_all on public.chapters;\ncreate policy chapters_select_all on public.chapters for select using (true);\ndrop policy if exists chapters_modify_auth on public.chapters;\ncreate policy chapters_modify_auth on public.chapters for all to authenticated using (true) with check (true);\n\n-- CONTENTS (public read, auth write)\nalter table if exists public.contents enable row level security;\ndrop policy if exists contents_select_all on public.contents;\ncreate policy contents_select_all on public.contents for select using (true);\ndrop policy if exists contents_modify_auth on public.contents;\ncreate policy contents_modify_auth on public.contents for all to authenticated using (true) with check (true);\n\n-- PROFILES (owner read/write only)\nalter table if exists public.profiles enable row level security;\ndrop policy if exists profiles_read_own on public.profiles;\ncreate policy profiles_read_own on public.profiles for select to authenticated using (id = auth.uid());\ndrop policy if exists profiles_update_own on public.profiles;\ncreate policy profiles_update_own on public.profiles for update to authenticated using (id = auth.uid()) with check (id = auth.uid());\n\n-- Foreign key supporting indexes (performance)\ncreate index if not exists idx_subjects_grade_id on public.subjects(grade_id);\ncreate index if not exists idx_chapters_grade_id on public.chapters(grade_id);\ncreate index if not exists idx_chapters_subject_id on public.chapters(subject_id);\ncreate index if not exists idx_contents_chapter_id on public.contents(chapter_id);\n\n-- Harden search_path for helper functions if present\nDO $$\nBEGIN\n  IF to_regprocedure('public.count_contents()') IS NOT NULL THEN\n    EXECUTE 'ALTER FUNCTION public.count_contents SET search_path = public, pg_temp';\n  END IF;\n  IF to_regprocedure('public.count_profiles()') IS NOT NULL THEN\n    EXECUTE 'ALTER FUNCTION public.count_profiles SET search_path = public, pg_temp';\n  END IF;\n  IF to_regprocedure('public.count_subjects()') IS NOT NULL THEN\n    EXECUTE 'ALTER FUNCTION public.count_subjects SET search_path = public, pg_temp';\n  END IF;\nEND$$;"}	rls_policies_and_indexes	ashiksiddike@gmail.com	\N
20250820025423	{"-- Remaining tables: activity, achievements, teams, team_members, friends, quizzes, results, users (app table)\n\n-- activity\nalter table if exists public.activity enable row level security;\ndrop policy if exists activity_select_all on public.activity;\ncreate policy activity_select_all on public.activity for select using (true);\ndrop policy if exists activity_modify_auth on public.activity;\ncreate policy activity_modify_auth on public.activity for all to authenticated using (true) with check (true);\n\n-- achievements\nalter table if exists public.achievements enable row level security;\ndrop policy if exists achievements_select_all on public.achievements;\ncreate policy achievements_select_all on public.achievements for select using (true);\ndrop policy if exists achievements_modify_auth on public.achievements;\ncreate policy achievements_modify_auth on public.achievements for all to authenticated using (true) with check (true);\n\n-- teams\nalter table if exists public.teams enable row level security;\ndrop policy if exists teams_select_all on public.teams;\ncreate policy teams_select_all on public.teams for select using (true);\ndrop policy if exists teams_modify_auth on public.teams;\ncreate policy teams_modify_auth on public.teams for all to authenticated using (true) with check (true);\n\n-- team_members\nalter table if exists public.team_members enable row level security;\ndrop policy if exists team_members_select_all on public.team_members;\ncreate policy team_members_select_all on public.team_members for select using (true);\ndrop policy if exists team_members_modify_auth on public.team_members;\ncreate policy team_members_modify_auth on public.team_members for all to authenticated using (true) with check (true);\n\n-- friends\nalter table if exists public.friends enable row level security;\ndrop policy if exists friends_select_all on public.friends;\ncreate policy friends_select_all on public.friends for select using (true);\ndrop policy if exists friends_modify_auth on public.friends;\ncreate policy friends_modify_auth on public.friends for all to authenticated using (true) with check (true);\n\n-- quizzes (public read, auth write)\nalter table if exists public.quizzes enable row level security;\ndrop policy if exists quizzes_select_all on public.quizzes;\ncreate policy quizzes_select_all on public.quizzes for select using (true);\ndrop policy if exists quizzes_modify_auth on public.quizzes;\ncreate policy quizzes_modify_auth on public.quizzes for all to authenticated using (true) with check (true);\n\n-- results (only owner can read own; keep simple here -> public read)\nalter table if exists public.results enable row level security;\ndrop policy if exists results_select_all on public.results;\ncreate policy results_select_all on public.results for select using (true);\ndrop policy if exists results_modify_auth on public.results;\ncreate policy results_modify_auth on public.results for all to authenticated using (true) with check (true);\n\n-- users (app table)\nalter table if exists public.users enable row level security;\ndrop policy if exists users_select_all on public.users;\ncreate policy users_select_all on public.users for select using (true);\ndrop policy if exists users_modify_auth on public.users;\ncreate policy users_modify_auth on public.users for all to authenticated using (true) with check (true);\n\n-- supporting indexes\ncreate index if not exists idx_friends_user_id on public.friends(user_id);\ncreate index if not exists idx_friends_friend_id on public.friends(friend_id);\ncreate index if not exists idx_results_user_id on public.results(user_id);\ncreate index if not exists idx_results_quiz_id on public.results(quiz_id);\ncreate index if not exists idx_quizzes_content_id on public.quizzes(content_id);"}	rls_remaining_tables	ashiksiddike@gmail.com	\N
20250820025437	{"alter table if exists public.goals enable row level security;\ndrop policy if exists goals_select_all on public.goals;\ncreate policy goals_select_all on public.goals for select using (true);\ndrop policy if exists goals_modify_auth on public.goals;\ncreate policy goals_modify_auth on public.goals for all to authenticated using (true) with check (true);"}	rls_goals	ashiksiddike@gmail.com	\N
\.


